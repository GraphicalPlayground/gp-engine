{
  "version": 4,
  "include": [
    "CMakePresetsBase.json"
  ],
  "configurePresets": [
    {
      "name": "macos-base",
      "hidden": true,
      "description": "Base preset for macOS builds",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-release",
      "inherits": ["macos-base", "release-base"],
      "description": "Release configuration for macOS"
    },
    {
      "name": "macos-debug",
      "inherits": ["macos-base", "debug-base"],
      "description": "Debug configuration for macOS"
    },
    {
      "name": "macos-profile",
      "inherits": ["macos-base", "profile-base"],
      "description": "Profile configuration for macOS"
    },
    {
      "name": "macos-development",
      "inherits": ["macos-base", "development-base"],
      "description": "Development configuration for macOS"
    },
    {
      "name": "macos-asan",
      "inherits": ["macos-base", "asan-base"],
      "description": "AddressSanitizer configuration for macOS"
    },
    {
      "name": "macos-ubsan",
      "inherits": ["macos-base", "ubsan-base"],
      "description": "UndefinedBehaviorSanitizer configuration for macOS"
    },
    {
      "name": "macos-tsan",
      "inherits": ["macos-base", "tsan-base"],
      "description": "ThreadSanitizer configuration for macOS"
    }
  ],
  "buildPresets": [
    {
      "name": "macos-base-build",
      "hidden": true,
      "description": "Base build preset for macOS builds",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-release",
      "inherits": "macos-base-build",
      "configurePreset": "macos-release",
      "displayName": "macOS Release",
      "description": "Release build configuration for macOS"
    },
    {
      "name": "macos-debug",
      "inherits": "macos-base-build",
      "configurePreset": "macos-debug",
      "displayName": "macOS Debug",
      "description": "Debug build configuration for macOS"
    },
    {
      "name": "macos-profile",
      "inherits": "macos-base-build",
      "configurePreset": "macos-profile",
      "displayName": "macOS Profile",
      "description": "Profile build configuration for macOS"
    },
    {
      "name": "macos-development",
      "inherits": "macos-base-build",
      "configurePreset": "macos-development",
      "displayName": "macOS Development",
      "description": "Development build configuration for macOS"
    },
    {
      "name": "macos-asan",
      "inherits": "macos-base-build",
      "configurePreset": "macos-asan",
      "displayName": "macOS AddressSanitizer",
      "description": "AddressSanitizer build configuration for macOS"
    },
    {
      "name": "macos-ubsan",
      "inherits": "macos-base-build",
      "configurePreset": "macos-ubsan",
      "displayName": "macOS UndefinedBehaviorSanitizer",
      "description": "UndefinedBehaviorSanitizer build configuration for macOS"
    },
    {
      "name": "macos-tsan",
      "inherits": "macos-base-build",
      "configurePreset": "macos-tsan",
      "displayName": "macOS ThreadSanitizer",
      "description": "ThreadSanitizer build configuration for macOS"
    }
  ]
}
