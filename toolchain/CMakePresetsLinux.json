{
  "version": 4,
  "include": [
    "CMakePresetsBase.json"
  ],
  "configurePresets": [
    {
      "name": "linux-base",
      "hidden": true,
      "description": "Base preset for Linux builds",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "FETCHCONTENT_BASE_DIR": "${sourceDir}/.cache/fetchcontent"
      }
    },
    {
      "name": "linux-release",
      "inherits": ["linux-base", "release-base"],
      "description": "Release configuration for Linux"
    },
    {
      "name": "linux-debug",
      "inherits": ["linux-base", "debug-base"],
      "description": "Debug configuration for Linux"
    },
    {
      "name": "linux-profile",
      "inherits": ["linux-base", "profile-base"],
      "description": "Profile configuration for Linux"
    },
    {
      "name": "linux-development",
      "inherits": ["linux-base", "development-base"],
      "description": "Development configuration for Linux"
    },
    {
      "name": "linux-asan",
      "inherits": ["linux-base", "asan-base"],
      "description": "AddressSanitizer configuration for Linux"
    },
    {
      "name": "linux-ubsan",
      "inherits": ["linux-base", "ubsan-base"],
      "description": "UndefinedBehaviorSanitizer configuration for Linux"
    },
    {
      "name": "linux-tsan",
      "inherits": ["linux-base", "tsan-base"],
      "description": "ThreadSanitizer configuration for Linux"
    },
    {
      "name": "linux-msan",
      "inherits": ["linux-base", "msan-base"],
      "description": "MemorySanitizer configuration for Linux"
    }
  ],
  "buildPresets": [
    {
      "name": "linux-base-build",
      "hidden": true,
      "description": "Base build preset for Linux builds",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-release",
      "inherits": "linux-base-build",
      "configurePreset": "linux-release",
      "displayName": "Linux Release",
      "description": "Release build configuration for Linux"
    },
    {
      "name": "linux-debug",
      "inherits": "linux-base-build",
      "configurePreset": "linux-debug",
      "displayName": "Linux Debug",
      "description": "Debug build configuration for Linux"
    },
    {
      "name": "linux-profile",
      "inherits": "linux-base-build",
      "configurePreset": "linux-profile",
      "displayName": "Linux Profile",
      "description": "Profile build configuration for Linux"
    },
    {
      "name": "linux-development",
      "inherits": "linux-base-build",
      "configurePreset": "linux-development",
      "displayName": "Linux Development",
      "description": "Development build configuration for Linux"
    },
    {
      "name": "linux-asan",
      "inherits": "linux-base-build",
      "configurePreset": "linux-asan",
      "displayName": "Linux AddressSanitizer",
      "description": "AddressSanitizer build configuration for Linux"
    },
    {
      "name": "linux-ubsan",
      "inherits": "linux-base-build",
      "configurePreset": "linux-ubsan",
      "displayName": "Linux UndefinedBehaviorSanitizer",
      "description": "UndefinedBehaviorSanitizer build configuration for Linux"
    },
    {
      "name": "linux-tsan",
      "inherits": "linux-base-build",
      "configurePreset": "linux-tsan",
      "displayName": "Linux ThreadSanitizer",
      "description": "ThreadSanitizer build configuration for Linux"
    },
    {
      "name": "linux-msan",
      "inherits": "linux-base-build",
      "configurePreset": "linux-msan",
      "displayName": "Linux MemorySanitizer",
      "description": "MemorySanitizer build configuration for Linux"
    }
  ]
}
