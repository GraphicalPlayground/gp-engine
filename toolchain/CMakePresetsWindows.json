{
  "version": 4,
  "include": [
    "CMakePresetsBase.json"
  ],
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "description": "Base preset for Windows builds",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl"
      }
    },
    {
      "name": "windows-release",
      "inherits": ["windows-base", "release-base"],
      "description": "Release configuration for Windows"
    },
    {
      "name": "windows-debug",
      "inherits": ["windows-base", "debug-base"],
      "description": "Debug configuration for Windows"
    },
    {
      "name": "windows-profile",
      "inherits": ["windows-base", "profile-base"],
      "description": "Profile configuration for Windows"
    },
    {
      "name": "windows-development",
      "inherits": ["windows-base", "development-base"],
      "description": "Development configuration for Windows"
    },
    {
      "name": "windows-asan",
      "inherits": ["windows-base", "asan-base"],
      "description": "AddressSanitizer configuration for Windows"
    }
  ],
  "buildPresets": [
    {
      "name": "windows-base-build",
      "hidden": true,
      "description": "Base build preset for Windows builds",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-release",
      "inherits": "windows-base-build",
      "configurePreset": "windows-release",
      "displayName": "Windows Release",
      "description": "Release build configuration for Windows"
    },
    {
      "name": "windows-debug",
      "inherits": "windows-base-build",
      "configurePreset": "windows-debug",
      "displayName": "Windows Debug",
      "description": "Debug build configuration for Windows"
    },
    {
      "name": "windows-profile",
      "inherits": "windows-base-build",
      "configurePreset": "windows-profile",
      "displayName": "Windows Profile",
      "description": "Profile build configuration for Windows"
    },
    {
      "name": "windows-development",
      "inherits": "windows-base-build",
      "configurePreset": "windows-development",
      "displayName": "Windows Development",
      "description": "Development build configuration for Windows"
    },
    {
      "name": "windows-asan",
      "inherits": "windows-base-build",
      "configurePreset": "windows-asan",
      "displayName": "Windows AddressSanitizer",
      "description": "AddressSanitizer build configuration for Windows"
    }
  ]
}
